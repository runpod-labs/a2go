{
  "$schema": "https://clawdbot.com/schema/config.json",
  "_comment": "Tier 3: GLM-4.7 - SOTA tool calling (~$7-8/hr)",

  "agents": {
    "defaults": {
      "model": {
        "primary": "runpod-vllm/glm-4.7"
      }
    }
  },

  "models": {
    "providers": {
      "runpod-vllm": {
        "baseUrl": "https://<POD_ID>-8000.proxy.runpod.net/v1",
        "apiKey": "${RUNPOD_VLLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "glm-4.7",
            "name": "GLM-4.7 (73.8% SWE-bench, 84.7% τ²-Bench)",
            "contextWindow": 65536,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "logging": {
    "level": "info"
  }
}
