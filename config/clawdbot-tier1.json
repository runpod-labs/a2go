{
  "$schema": "https://clawdbot.com/schema/config.json",
  "_comment": "Tier 1: Qwen3-30B-A3B - Best for validation (~$2/hr)",

  "agents": {
    "defaults": {
      "model": {
        "primary": "runpod-vllm/qwen3-30b-a3b"
      }
    }
  },

  "models": {
    "providers": {
      "runpod-vllm": {
        "baseUrl": "https://<POD_ID>-8000.proxy.runpod.net/v1",
        "apiKey": "${RUNPOD_VLLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3-30b-a3b",
            "name": "Qwen3-30B-A3B (69.6% SWE-bench)",
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "logging": {
    "level": "info"
  }
}
