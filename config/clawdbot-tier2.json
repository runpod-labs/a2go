{
  "$schema": "https://clawdbot.com/schema/config.json",
  "_comment": "Tier 2: MiMo-V2-Flash - Fastest inference (~$4/hr)",

  "agents": {
    "defaults": {
      "model": {
        "primary": "runpod-vllm/mimo-v2-flash"
      }
    }
  },

  "models": {
    "providers": {
      "runpod-vllm": {
        "baseUrl": "https://<POD_ID>-8000.proxy.runpod.net/v1",
        "apiKey": "${RUNPOD_VLLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "mimo-v2-flash",
            "name": "MiMo-V2-Flash (73.4% SWE-bench, 150 tok/s)",
            "contextWindow": 65536,
            "maxTokens": 8192
          }
        ]
      }
    }
  },

  "logging": {
    "level": "info"
  }
}
