# Dockerfile.unified - Unified OpenClaw2Go image
#
# Uses pre-built llama.cpp binaries from the engines image (no compilation).
# Build the engines image first: see engines/Dockerfile and engines-build.yml.
#
# Multi-stage build:
#   Stage 1 (build-imggen): Build image-gen Python venv in devel image
#   Stage 2 (runtime):      Slim runtime with only pre-built artifacts
#
# vLLM was removed to reduce image size (~5-6 GB savings). All current models
# work with llama.cpp (including FP16 via GGUF). vLLM can be added back as a
# separate build variant (openclaw2go:full) if a future model requires it.
#
# Configuration at runtime via OPENCLAW_CONFIG env var:
#   {"llm": true, "audio": true, "image": true}                  — all defaults
#   {"llm": true, "audio": true}                                   — LLM + audio only
#   {"llm": "unsloth/GLM-4.7-Flash-GGUF", "contextLength": 200000} — HuggingFace name
#   {"profile": "rtx5090-full-stack"}                              — use a preset
#
# Model names are case-insensitive. Use HuggingFace repo names or short IDs.
#
# Build: docker build -f Dockerfile.unified -t openclaw2go .

ARG ENGINES_IMAGE=runpod/openclaw2go-engines:latest
ARG CUDA_VERSION=12.8
ARG UBUNTU_VERSION=24.04

# Pull pre-built engines (llama.cpp LLM + Audio binaries)
FROM ${ENGINES_IMAGE} AS engines

# ============================================================
# Stage 1: Build image-gen venv
# ============================================================
FROM nvcr.io/nvidia/cuda-dl-base:25.03-cuda${CUDA_VERSION}-devel-ubuntu${UBUNTU_VERSION} AS build-imggen

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-dev python3-venv python3-pip \
    && rm -f /usr/lib/python*/EXTERNALLY-MANAGED \
    && rm -rf /var/lib/apt/lists/*

# PyTorch cu128 required for RTX 5090 (Blackwell sm_120), works on all others too
# Diffusers from git required for Flux2KleinPipeline
RUN python3 -m venv /opt/engines/image-gen/venv && \
    /opt/engines/image-gen/venv/bin/pip install --no-cache-dir \
        torch --index-url https://download.pytorch.org/whl/cu128 && \
    /opt/engines/image-gen/venv/bin/pip install --no-cache-dir \
        sdnq git+https://github.com/huggingface/diffusers.git \
        transformers accelerate safetensors

# ============================================================
# Stage 2: Slim runtime image
# ============================================================
FROM nvidia/cuda:${CUDA_VERSION}.1-runtime-ubuntu${UBUNTU_VERSION}

ARG CUDA_VERSION
ENV DEBIAN_FRONTEND=noninteractive

# Runtime-only system dependencies (no build tools)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git sudo unzip libgomp1 \
    python3 python3-venv python3-pip \
    openssh-server \
    && rm -f /etc/ssh/ssh_host_* && mkdir -p /var/run/sshd \
    && rm -f /usr/lib/python*/EXTERNALLY-MANAGED \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# ── Engine: llamacpp-llm ──────────────────────────────────
# CRITICAL: LLM and Audio libs MUST be separate (incompatible .so files)
COPY --from=engines /opt/engines/llamacpp-llm/ /opt/engines/llamacpp-llm/
RUN ldconfig /opt/engines/llamacpp-llm/lib/

# ── Engine: llamacpp-audio ────────────────────────────────
# Audio libs are NOT registered with ldconfig — entrypoint sets LD_LIBRARY_PATH per-engine
COPY --from=engines /opt/engines/llamacpp-audio/ /opt/engines/llamacpp-audio/

# ── Engine: llamacpp-glm-dsa ──────────────────────────────
# GLM-5 MoE DSA support (PR #19460 - experimental)
# Libs NOT registered with ldconfig — entrypoint sets LD_LIBRARY_PATH per-engine
COPY --from=engines /opt/engines/llamacpp-glm-dsa/ /opt/engines/llamacpp-glm-dsa/

# ── Engine: ik-llamacpp ─────────────────────────────────────
# ik_llama.cpp fork (custom quants: IQ2_KS, smol-IQ3_KS, etc.)
# Libs NOT registered with ldconfig — entrypoint sets LD_LIBRARY_PATH per-engine
COPY --from=engines /opt/engines/ik-llamacpp/ /opt/engines/ik-llamacpp/

# ── Engine: image-gen (pre-built venv from Stage 1) ───────
COPY --from=build-imggen /opt/engines/image-gen/venv/ /opt/engines/image-gen/venv/

# ── Node.js + GitHub CLI ──────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | \
    dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y --no-install-recommends nodejs gh && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# ── Python tools ──────────────────────────────────────────
RUN python3 -m pip install --no-cache-dir huggingface_hub

# ── OpenClaw + Claude Code ────────────────────────────────
RUN npm install -g --prefer-offline @anthropic-ai/claude-code openclaw@latest && \
    npm cache clean --force

WORKDIR /

# ── Environment defaults ──────────────────────────────────
ENV LLAMA_API_KEY="changeme" \
    OPENCLAW_WEB_PASSWORD="changeme" \
    OPENCLAW_STATE_DIR="/workspace/.openclaw" \
    OPENCLAW_WORKSPACE="/workspace/openclaw" \
    OPENCLAW_REGISTRY_DIR="/opt/openclaw/registry" \
    OPENCLAW_REGISTRY_URL="https://runpod-workers.github.io/openclaw2go-registry/v1/catalog.json" \
    OPENCLAW_REGISTRY_OFFLINE="" \
    OPENCLAW_REGISTRY_TTL_SECONDS="3600"

# ── Copy application files ────────────────────────────────
COPY registry/ /opt/openclaw/registry/
COPY registry/templates/ /opt/openclaw/templates/
COPY skills/ /opt/openclaw/skills/
COPY web/ /opt/openclaw/web/
COPY plugins/ /opt/openclaw/plugins/
COPY config/ /opt/openclaw/config/
COPY scripts/entrypoint-common.sh /opt/openclaw/entrypoint-common.sh
COPY scripts/entrypoint-unified.sh /opt/openclaw/entrypoint-unified.sh
COPY scripts/resolve-profile.py /opt/openclaw/scripts/resolve-profile.py
COPY scripts/vram-budget.py /opt/openclaw/scripts/vram-budget.py
COPY scripts/openclaw-profiles /usr/local/bin/openclaw-profiles
COPY scripts/openclaw2go /usr/local/bin/openclaw2go
COPY scripts/openclaw-image-gen /usr/local/bin/openclaw-image-gen
COPY scripts/openclaw-image-server /usr/local/bin/openclaw-image-server
COPY scripts/openclaw-tts /usr/local/bin/openclaw-tts
COPY scripts/openclaw-stt /usr/local/bin/openclaw-stt
COPY scripts/openclaw-web-proxy /usr/local/bin/openclaw-web-proxy

RUN chmod +x /opt/openclaw/entrypoint-unified.sh \
    /opt/openclaw/scripts/resolve-profile.py \
    /opt/openclaw/scripts/vram-budget.py \
    /usr/local/bin/openclaw-profiles \
    /usr/local/bin/openclaw2go \
    /usr/local/bin/openclaw-image-gen \
    /usr/local/bin/openclaw-image-server \
    /usr/local/bin/openclaw-tts \
    /usr/local/bin/openclaw-stt \
    /usr/local/bin/openclaw-web-proxy

EXPOSE 8000 8080 18789 22
ENTRYPOINT ["/opt/openclaw/entrypoint-unified.sh"]
