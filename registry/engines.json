{
  "openclaw2go-llamacpp": {
    "id": "openclaw2go-llamacpp",
    "name": "openclaw2go-llamacpp (unified fork)",
    "description": "Unified llama.cpp fork merging main + audio/TTS, GLM-5 DSA, OuteTTS 1.0, Eagle-3",
    "binary": "/opt/engines/openclaw2go-llamacpp/bin/llama-server",
    "binaryTts": "/opt/engines/openclaw2go-llamacpp/bin/llama-tts",
    "binaryAudio": "/opt/engines/openclaw2go-llamacpp/bin/llama-liquid-audio-server",
    "libPath": "/opt/engines/openclaw2go-llamacpp/lib",
    "type": "native",
    "source": "https://github.com/runpod-workers/openclaw2go-llamacpp"
  },
  "ik-llamacpp": {
    "id": "ik-llamacpp",
    "name": "ik_llama.cpp (custom quants)",
    "description": "ikawrakow fork with custom GGML types (IQ2_KS, smol-IQ3_KS, type 139+)",
    "binary": "/opt/engines/ik-llamacpp/bin/llama-server",
    "libPath": "/opt/engines/ik-llamacpp/lib",
    "type": "native",
    "source": "https://github.com/ikawrakow/ik_llama.cpp"
  },
  "image-gen": {
    "id": "image-gen",
    "name": "Image Generation (Diffusers + SDNQ)",
    "binary": "/usr/local/bin/openclaw-image-server",
    "venvPath": "/opt/engines/image-gen/venv",
    "type": "python-venv"
  }
}
