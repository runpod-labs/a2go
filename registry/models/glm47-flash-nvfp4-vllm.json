{
  "id": "gadflyii/glm47-flash-nvfp4",
  "name": "GLM-4.7-Flash NVFP4 (vLLM)",
  "type": "llm",
  "engine": "vllm",
  "repo": "GadflyII/GLM-4.7-Flash-NVFP4",
  "downloadMode": "repo",
  "downloadDir": "/workspace/models/GLM-4.7-Flash-NVFP4",
  "servedAs": "glm-4.7-flash",
  "vram": { "model": 12000, "overhead": 2000 },
  "defaults": { "contextLength": 200000, "port": 8000 },
  "startDefaults": { "gpuMemoryUtilization": "0.92" },
  "extraStartArgs": [
    "--trust-remote-code",
    "--enable-auto-tool-choice", "--tool-call-parser", "glm47",
    "--reasoning-parser", "glm45",
    "--block-size", "32",
    "--enable-prefix-caching"
  ],
  "provider": { "name": "local-vllm", "api": "openai-completions" },
  "default": false,
  "status": "experimental"
}
