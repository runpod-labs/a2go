#!/usr/bin/env python3
"""
openclaw2go - CLI for OpenClaw2Go model/profile management and registry export.

Usage:
  openclaw2go models                        List all available models by type
  openclaw2go models --type llm             List models of a specific type
  openclaw2go fit                           Show what fits on detected GPU
  openclaw2go fit --vram 32768              Show what fits on a specific VRAM
  openclaw2go presets                       List available presets
  openclaw2go presets show <id>             Show preset details
  openclaw2go validate <json-string>        Validate an OPENCLAW_CONFIG

  openclaw2go registry export               Export current model config + test evidence
  openclaw2go registry export --format issue  Formatted for GitHub Issue
  openclaw2go registry export --format json   Raw JSON only
"""

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

REGISTRY_DIR = Path(os.environ.get("OPENCLAW_REGISTRY_DIR", "/opt/openclaw/registry"))
KV_CACHE_MB_PER_1K_TOKENS = 40


# ── Shared helpers ────────────────────────────────────────────

def load_json(path):
    with open(path, "r", encoding="utf-8") as f:
        return json.load(f)


def load_all_json(directory):
    result = {}
    d = Path(directory)
    if not d.is_dir():
        return result
    for f in d.glob("*.json"):
        data = load_json(f)
        key = data.get("id", f.stem)
        result[key] = data
    return result


def find_model(value, models):
    """Find a model by ID or HuggingFace repo name (case-insensitive)."""
    if value in models:
        return models[value]
    value_lower = value.lower()
    for model_id, model in models.items():
        if model_id.lower() == value_lower:
            return model
    for model_id, model in models.items():
        repo = model.get("repo", "")
        if repo.lower() == value_lower:
            return model
    return None


def detect_gpu():
    try:
        out = subprocess.check_output(
            ["nvidia-smi", "--query-gpu=name,memory.total,memory.used",
             "--format=csv,noheader,nounits"],
            text=True, timeout=10
        ).strip()
    except (subprocess.SubprocessError, FileNotFoundError):
        return None, 0, 0

    line = out.splitlines()[0] if out else ""
    parts = [p.strip() for p in line.split(",")]
    if len(parts) < 3:
        return parts[0] if parts else None, 0, 0

    name = parts[0]
    try:
        vram_mb = int(parts[1])
    except ValueError:
        vram_mb = 0
    try:
        vram_used = int(parts[2])
    except ValueError:
        vram_used = 0
    return name, vram_mb, vram_used


def match_gpu(gpu_name, gpu_registry):
    if not gpu_name:
        return None
    name_lower = gpu_name.lower()
    for gpu_id, gpu in gpu_registry.items():
        registry_name = gpu["name"].lower()
        for token in registry_name.split():
            if token in name_lower:
                return gpu
    return None


def compute_max_context(vram_available_mb, llm_model):
    if llm_model.get("engine") == "vllm":
        return llm_model.get("defaults", {}).get("contextLength", 65536)
    base_vram = llm_model["vram"]["model"] + llm_model["vram"]["overhead"]
    available_for_kv = vram_available_mb - base_vram
    if available_for_kv <= 0:
        return 0
    kv_rate = llm_model.get("kvCacheMbPer1kTokens", KV_CACHE_MB_PER_1K_TOKENS)
    return int((available_for_kv / kv_rate) * 1000)


# ── Command: models ───────────────────────────────────────────

def cmd_models(args):
    """List available models, grouped by type."""
    models = load_all_json(REGISTRY_DIR / "models")
    engines = load_json(REGISTRY_DIR / "engines.json")

    type_filter = args.type if hasattr(args, "type") and args.type else None

    by_type = {}
    for mid, model in models.items():
        mtype = model.get("type", "unknown")
        if type_filter and mtype != type_filter:
            continue
        by_type.setdefault(mtype, []).append(model)

    for mtype in ("llm", "audio", "image"):
        group = by_type.get(mtype, [])
        if not group:
            continue

        print(f"\n{mtype.upper()} Models:")
        print(f"  {'ID':<25s} {'Name':<40s} {'VRAM':<12s} {'Default':<8s} {'Status'}")
        print(f"  {'─' * 95}")

        for model in sorted(group, key=lambda m: m["id"]):
            vram = model["vram"]["model"] + model["vram"]["overhead"]
            default = "yes" if model.get("default") else ""
            status = model.get("status", "?")
            engine_id = model.get("engine", "?")
            engine = engines.get(engine_id, {})
            engine_name = engine.get("name", engine_id)

            print(f"  {model['id']:<25s} {model['name']:<40s} {vram:>5d} MB    {default:<8s} {status}")
            print(f"    Engine: {engine_name}  |  Repo: {model.get('repo', '?')}")

    for mtype, group in by_type.items():
        if mtype in ("llm", "audio", "image"):
            continue
        print(f"\n{mtype.upper()} Models:")
        for model in group:
            print(f"  {model['id']}: {model['name']}")


# ── Command: fit ──────────────────────────────────────────────

def cmd_fit(args):
    """Show what model combinations fit on the GPU."""
    models = load_all_json(REGISTRY_DIR / "models")
    gpus = load_all_json(REGISTRY_DIR / "gpus")

    if args.vram:
        gpu_name = "custom"
        gpu_vram = args.vram
    else:
        gpu_name, gpu_vram, _ = detect_gpu()

    detected = match_gpu(gpu_name, gpus) if not args.vram else None

    print(f"GPU: {gpu_name or 'none'} ({gpu_vram:,} MB VRAM)")
    if detected:
        print(f"Registry match: {detected['id']}")
    print()

    if gpu_vram <= 0:
        print("ERROR: no GPU detected and --vram not specified")
        sys.exit(1)

    defaults = {}
    for mtype in ("llm", "audio", "image"):
        for mid, model in models.items():
            if model.get("type") == mtype and model.get("default"):
                defaults[mtype] = model
                break

    combos = [
        ("LLM + Audio + Image", ["llm", "audio", "image"]),
        ("LLM + Audio", ["llm", "audio"]),
        ("LLM + Image", ["llm", "image"]),
        ("LLM only", ["llm"]),
    ]

    for label, roles in combos:
        selected = {}
        for role in roles:
            if role in defaults:
                selected[role] = defaults[role]

        if "llm" not in selected:
            continue

        non_llm_vram = sum(
            m["vram"]["model"] + m["vram"]["overhead"]
            for r, m in selected.items() if r != "llm"
        )

        llm = selected["llm"]
        vram_for_llm = gpu_vram - non_llm_vram
        max_ctx = compute_max_context(vram_for_llm, llm)
        base_vram = sum(m["vram"]["model"] + m["vram"]["overhead"] for m in selected.values())

        is_vllm = llm.get("engine") == "vllm"

        if is_vllm:
            total_vram = base_vram
            fits = total_vram <= gpu_vram
        else:
            default_ctx = llm.get("defaults", {}).get("contextLength", 150000)
            capped_ctx = min(max_ctx, default_ctx) if max_ctx > 0 else 0
            llm_kv_rate = llm.get("kvCacheMbPer1kTokens", KV_CACHE_MB_PER_1K_TOKENS)
            kv_vram = int((capped_ctx / 1000) * llm_kv_rate) if capped_ctx > 0 else 0
            total_vram = base_vram + kv_vram
            fits = total_vram <= gpu_vram

        marker = "OK" if fits else "NO"
        free = gpu_vram - total_vram

        print(f"  {label:<25s}  [{marker}]")
        model_parts = []
        for role in roles:
            m = selected.get(role)
            if m:
                v = m["vram"]["model"] + m["vram"]["overhead"]
                model_parts.append(f"{role}: {m['name']} ({v:,} MB)")
        for part in model_parts:
            print(f"    {part}")
        if fits and is_vllm:
            print(f"    Context: {max_ctx:,} tokens (vLLM auto KV)  |  Model VRAM: {total_vram:,} MB, {free:,} MB free")
        elif fits and max_ctx > 0:
            print(f"    Max context: {max_ctx:,} tokens  |  Default context ({capped_ctx:,}): {total_vram:,} MB used, {free:,} MB free")
        elif not fits:
            print(f"    Needs {total_vram:,} MB, have {gpu_vram:,} MB ({total_vram - gpu_vram:,} MB over)")
        print()


# ── Command: presets ──────────────────────────────────────────

def cmd_presets(args):
    """List profile presets."""
    profiles = load_all_json(REGISTRY_DIR / "profiles")

    print(f"{'ID':<30s} {'Name':<30s} {'GPU':<15s} {'Services':<25s} {'VRAM':<10s} {'Status'}")
    print("─" * 115)

    for pid, profile in sorted(profiles.items()):
        gpu_id = profile.get("gpu", "?")
        roles = ", ".join(s["role"] for s in profile.get("services", []))
        vram = profile.get("vramTotal", 0)
        status = profile.get("status", "?")

        print(f"{pid:<30s} {profile['name']:<30s} {gpu_id:<15s} {roles:<25s} {vram:>5d} MB  {status}")


def cmd_presets_show(args):
    """Show details of a preset."""
    profiles = load_all_json(REGISTRY_DIR / "profiles")
    models = load_all_json(REGISTRY_DIR / "models")
    gpus = load_all_json(REGISTRY_DIR / "gpus")
    engines = load_json(REGISTRY_DIR / "engines.json")

    profile_id = args.preset_id
    if profile_id not in profiles:
        print(f"ERROR: unknown preset '{profile_id}'")
        print(f"Available: {', '.join(sorted(profiles.keys()))}")
        sys.exit(1)

    profile = profiles[profile_id]
    gpu = gpus.get(profile.get("gpu", ""))

    print(f"Preset: {profile['name']} ({profile['id']})")
    print(f"GPU: {gpu['name'] if gpu else profile.get('gpu', '?')} ({gpu['vramMb'] if gpu else '?'} MB)")
    print(f"Status: {profile.get('status', '?')}")
    print(f"Web Proxy: {'yes' if profile.get('webProxy') else 'no'}")
    print()

    print("Services:")
    print(f"  {'Role':<10s} {'Model':<35s} {'Engine':<20s} {'Port':<6s} {'VRAM':<10s}")
    print(f"  {'─' * 85}")

    total_vram = 0
    for svc in profile["services"]:
        model_id = svc["model"]
        model = models.get(model_id, {})
        engine_id = model.get("engine", "?")
        engine = engines.get(engine_id, {})
        port = svc.get("port", model.get("defaults", {}).get("port", "?"))
        vram = model.get("vram", {})
        vram_total = vram.get("model", 0) + vram.get("overhead", 0)
        total_vram += vram_total

        overrides = svc.get("overrides", {})
        override_str = ""
        if overrides:
            parts = [f"{k}={v}" for k, v in overrides.items()]
            override_str = f" [{', '.join(parts)}]"

        print(
            f"  {svc['role']:<10s} {model.get('name', model_id):<35s} "
            f"{engine.get('name', engine_id):<20s} {str(port):<6s} {vram_total:>5d} MB{override_str}"
        )

    print(f"  {'─' * 85}")
    print(f"  {'Total VRAM':<67s} {total_vram:>5d} MB")
    if gpu:
        free = gpu["vramMb"] - total_vram
        print(f"  {'Free VRAM':<67s} {free:>5d} MB")


# ── Command: validate ─────────────────────────────────────────

def cmd_validate(args):
    """Validate an OPENCLAW_CONFIG JSON string."""
    models = load_all_json(REGISTRY_DIR / "models")
    profiles = load_all_json(REGISTRY_DIR / "profiles")

    try:
        config = json.loads(args.config_json)
    except json.JSONDecodeError as e:
        print(f"ERROR: invalid JSON: {e}")
        sys.exit(1)

    errors = []

    if "profile" in config:
        if config["profile"] not in profiles:
            errors.append(f"unknown preset '{config['profile']}'")
    else:
        for role in ("llm", "audio", "image"):
            value = config.get(role)
            if value is None or value is False or value is True:
                continue
            if isinstance(value, str) and not find_model(value, models):
                available = [f"{m} ({d.get('repo', '')})" for m, d in models.items() if d.get("type") == role]
                errors.append(f"unknown model '{value}' for role '{role}'. Available: {', '.join(available)}")

    if errors:
        print("Validation FAILED:")
        for e in errors:
            print(f"  - {e}")
        sys.exit(1)
    else:
        print("Validation OK")
        print(f"Config: {json.dumps(config, indent=2)}")


# ── Command: registry export ──────────────────────────────────

def cmd_registry_export(args):
    """Export current running model config + test evidence for community contribution."""
    fmt = args.format if hasattr(args, "format") and args.format else "json"

    # Collect GPU info
    gpu_name, gpu_vram, gpu_used = detect_gpu()

    # Read running LLM config from temp files written by entrypoint
    llm_model_name = _read_file("/tmp/oc_llm_model_name")
    llm_context = _read_file("/tmp/oc_llm_context")
    llm_port = _read_file("/tmp/oc_llm_port") or "8000"

    # Health check
    health_ok = False
    try:
        import urllib.request
        with urllib.request.urlopen(f"http://localhost:{llm_port}/health", timeout=3) as resp:
            health_ok = resp.status == 200
    except Exception:
        pass

    # Find the current model config from registry
    models = load_all_json(REGISTRY_DIR / "models")
    current_model = None
    if llm_model_name:
        for mid, model in models.items():
            if model.get("servedAs") == llm_model_name:
                current_model = model
                break

    if not current_model:
        print("ERROR: could not detect running model. Is the LLM server started?", file=sys.stderr)
        print("Make sure you run this command inside a running OpenClaw2Go pod.", file=sys.stderr)
        sys.exit(1)

    # Build export data
    export = {
        "model": current_model,
        "testEvidence": {
            "gpu": gpu_name,
            "gpuVramMb": gpu_vram,
            "gpuVramUsedMb": gpu_used,
            "contextLength": int(llm_context) if llm_context else None,
            "healthCheck": "pass" if health_ok else "fail",
        },
    }

    if fmt == "json":
        print(json.dumps(export, indent=2))

    elif fmt == "issue":
        model = current_model
        print("## New Model Submission")
        print()
        print(f"**Model ID**: `{model['id']}`")
        print(f"**Name**: {model['name']}")
        print(f"**Type**: {model.get('type', 'llm')}")
        print(f"**Engine**: {model.get('engine', 'llamacpp')}")
        print(f"**HuggingFace Repo**: [{model.get('repo', '')}](https://huggingface.co/{model.get('repo', '')})")
        print()
        print("### Model Config")
        print()
        print("```json")
        print(json.dumps(model, indent=2))
        print("```")
        print()
        print("### Test Evidence")
        print()
        print(f"- **GPU**: {gpu_name}")
        print(f"- **VRAM**: {gpu_vram:,} MB total, {gpu_used:,} MB used")
        print(f"- **Context Length**: {llm_context or 'N/A'}")
        print(f"- **Health Check**: {'PASS' if health_ok else 'FAIL'}")

    else:
        print(f"ERROR: unknown format '{fmt}'. Use 'json' or 'issue'.", file=sys.stderr)
        sys.exit(1)


def _read_file(path):
    """Read a single-line file, returning stripped content or None."""
    try:
        return Path(path).read_text().strip()
    except (OSError, FileNotFoundError):
        return None


# ── Command: registry status ──────────────────────────────────

def cmd_registry_status(args):
    """Show current registry status (source, cache age, model counts)."""
    cache_dir = Path("/workspace/.openclaw/registry")
    cache_meta = cache_dir / ".fetch-meta.json"

    print(f"Registry dir: {REGISTRY_DIR}")
    print()

    if cache_meta.exists():
        try:
            import time
            meta = json.loads(cache_meta.read_text())
            fetched_at = meta.get("fetchedAt", 0)
            age = time.time() - fetched_at
            age_str = f"{int(age)}s ago" if age < 3600 else f"{age / 3600:.1f}h ago"
            print(f"Cache: {cache_dir}")
            print(f"  Last fetched: {age_str}")
            print(f"  URL: {meta.get('url', 'unknown')}")
            print(f"  External models accepted: {meta.get('modelsAccepted', '?')}")
            print(f"  External models skipped: {meta.get('modelsSkipped', '?')}")
            print(f"  External profiles accepted: {meta.get('profilesAccepted', '?')}")
        except (json.JSONDecodeError, OSError):
            print("Cache: corrupted metadata")
    else:
        print("Cache: not present (using baked-in registry)")

    print()
    models = load_all_json(REGISTRY_DIR / "models")
    profiles = load_all_json(REGISTRY_DIR / "profiles")
    print(f"Models loaded: {len(models)}")
    for mtype in ("llm", "audio", "image"):
        count = sum(1 for m in models.values() if m.get("type") == mtype)
        if count:
            print(f"  {mtype}: {count}")
    print(f"Profiles loaded: {len(profiles)}")


# ── Main ──────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(
        prog="openclaw2go",
        description="OpenClaw2Go CLI — model management, GPU fit check, and registry tools",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  openclaw2go models                         List all available models
  openclaw2go models --type llm              List LLM models only
  openclaw2go fit                            Show what fits on detected GPU
  openclaw2go fit --vram 81920               Show what fits on 80GB GPU
  openclaw2go presets                        List preset profiles
  openclaw2go presets show <id>              Show preset details
  openclaw2go validate '{"llm":true}'        Validate a config
  openclaw2go registry export                Export current model config (JSON)
  openclaw2go registry export --format issue Export formatted for GitHub Issue
  openclaw2go registry status                Show registry source and cache info
"""
    )
    sub = parser.add_subparsers(dest="command")

    # models
    models_parser = sub.add_parser("models", help="List available models")
    models_parser.add_argument("--type", choices=["llm", "audio", "image"], help="Filter by model type")

    # fit
    fit_parser = sub.add_parser("fit", help="Show what fits on this GPU")
    fit_parser.add_argument("--vram", type=int, help="Override VRAM in MB (skip GPU detection)")

    # presets
    presets_parser = sub.add_parser("presets", help="List/show preset profiles")
    presets_sub = presets_parser.add_subparsers(dest="presets_command")
    presets_show = presets_sub.add_parser("show", help="Show preset details")
    presets_show.add_argument("preset_id", help="Preset ID")

    # validate
    validate_parser = sub.add_parser("validate", help="Validate an OPENCLAW_CONFIG JSON")
    validate_parser.add_argument("config_json", help="JSON string to validate")

    # registry
    registry_parser = sub.add_parser("registry", help="Registry tools (export, status)")
    registry_sub = registry_parser.add_subparsers(dest="registry_command")

    export_parser = registry_sub.add_parser("export", help="Export current model config + test evidence")
    export_parser.add_argument("--format", choices=["json", "issue"], default="json",
                               help="Output format (default: json)")

    registry_sub.add_parser("status", help="Show registry source and cache info")

    args = parser.parse_args()

    if args.command == "models":
        cmd_models(args)
    elif args.command == "fit":
        cmd_fit(args)
    elif args.command == "presets":
        if hasattr(args, "presets_command") and args.presets_command == "show":
            cmd_presets_show(args)
        else:
            cmd_presets(args)
    elif args.command == "validate":
        cmd_validate(args)
    elif args.command == "registry":
        if hasattr(args, "registry_command") and args.registry_command == "export":
            cmd_registry_export(args)
        elif hasattr(args, "registry_command") and args.registry_command == "status":
            cmd_registry_status(args)
        else:
            registry_parser.print_help()
            sys.exit(1)
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
